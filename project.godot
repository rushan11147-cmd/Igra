; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Horror Factory"
config/description="Психологический хоррор с элементами симулятора производства. Переживите ночную смену на заводе."
run/main_scene="res://scenes/ui/main_menu/MainMenu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SettingsManager="*res://scripts/autoload/settings_manager.gd"
SceneLoader="*res://scripts/autoload/scene_loader.gd"
EventBus="*res://scripts/autoload/event_bus.gd"
DisplayManager="*res://scripts/autoload/display_manager.gd"
SoundLibrary="*res://scripts/autoload/sound_library.gd"
GameManager="*res://scripts/autoload/game_manager.gd"
ShiftManager="*res://scripts/autoload/shift_manager.gd"
HorrorSystem="*res://scripts/autoload/horror_system.gd"
StoryManager="*res://scripts/autoload/story_manager.gd"
AreaManager="*res://scripts/autoload/area_manager.gd"
InventoryManager="*res://scripts/autoload/inventory_manager.gd"
MonsterMemory="*res://scripts/autoload/monster_memory.gd"
SanitySystem="*res://scripts/autoload/sanity_system.gd"
FactoryRules="*res://scripts/autoload/factory_rules.gd"
LivingFactory="*res://scripts/autoload/living_factory.gd"
NightEvents="*res://scripts/autoload/night_events.gd"
CreatureManager="*res://scripts/autoload/creature_manager.gd"
RadioPartner="*res://scripts/autoload/radio_partner.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=4
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

